{
  "openapi": "3.0.0",
  "info": {
    "title": "Finance Pro API",
    "version": "1.0.0",
    "description": "Documentação da API do sistema Finance Pro Mobile"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desenvolvimento"
    }
  ],
  "paths": {
    "/api/finance/dashboard": {
      "get": {
        "summary": "Obter dados do dashboard",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dados do dashboard retornados com sucesso"
          }
        }
      }
    },
    "/api/finance/transactions": {
      "get": {
        "summary": "Listar transações",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de transações"
          }
        }
      },
      "post": {
        "summary": "Criar nova transação",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "string" },
                  "accountId": { "type": "integer" },
                  "categoryId": { "type": "integer" },
                  "type": { "type": "string", "enum": ["income", "expense"] },
                  "amount": { "type": "number" },
                  "description": { "type": "string" },
                  "date": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transação criada"
          }
        }
      }
    }
  }
}
